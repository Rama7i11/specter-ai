# ─────────────────────────────────────────────
#  SPECTER-AI  –  Environment Variables
#  Copy to .env and fill in real values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── Gemini Live API ──────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Model used for the Live API (audio <-> audio via WebSocket)
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001

# ── Wazuh Manager ───────────────────────────
WAZUH_API_URL=https://localhost:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASS=your_wazuh_api_password_here
# Agent ID where active-response commands are sent (usually "000" for manager)
WAZUH_AGENT_ID=000

# ── Hardware / Argon Particle ────────────────
# Full URL to the Argon Particle endpoint (provided by hardware team)
HARDWARE_ENDPOINT=https://api.particle.io/v1/devices/YOUR_DEVICE_ID/YOUR_EVENT

# ── Backend ──────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Secret token that Wazuh Integrator sends in X-Auth-Token header
WEBHOOK_SECRET=change_me_webhook_secret

# ── ngrok ────────────────────────────────────
# Set after `ngrok http 8000`; used so hardware team can reach /hardware-alert
NGROK_URL=https://xxxx-xx-xx-xxx-xxx.ngrok-free.app

# ── MySQL (bank lab DB) ──────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=bankdb
MYSQL_USER=bankuser
MYSQL_PASSWORD=bankpass
MYSQL_ROOT_PASSWORD=rootpass

# ── Wazuh Indexer / Dashboard ────────────────
# Password for OpenSearch admin user (also used by Wazuh dashboard)
INDEXER_PASSWORD=SecretPassword
# Password for the Kibana/OpenSearch Dashboards server user
DASHBOARD_PASSWORD=kibanaserver

# ── Demo helpers ─────────────────────────────
# Number of fake users to seed in /demo/seed
DEMO_SEED_COUNT=10
