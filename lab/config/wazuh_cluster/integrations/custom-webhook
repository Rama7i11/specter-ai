#!/usr/bin/env python3
"""
Wazuh custom integration: POST alert JSON to SPECTER-AI backend webhook.
Called by Wazuh integrator as: custom-webhook <alert_file> <api_key> <hook_url>
"""
import json
import sys
import urllib.request
import urllib.error


def main():
    if len(sys.argv) < 4:
        sys.stderr.write("Usage: custom-webhook <alert_file> <api_key> <hook_url>\n")
        sys.exit(1)

    alert_file = sys.argv[1]
    api_key    = sys.argv[2]
    hook_url   = sys.argv[3]

    with open(alert_file, encoding="utf-8") as f:
        alert = json.load(f)

    payload = json.dumps(alert).encode("utf-8")
    req = urllib.request.Request(
        hook_url,
        data=payload,
        headers={
            "Content-Type": "application/json",
            "X-Auth-Token": api_key,
        },
        method="POST",
    )

    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            sys.stdout.write(f"webhook ok: {resp.status}\n")
    except urllib.error.URLError as exc:
        sys.stderr.write(f"webhook error: {exc}\n")
        sys.exit(1)


if __name__ == "__main__":
    main()
